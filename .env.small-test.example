# Temu Listing Workbench small-scale test env

# Backend
TEMU_WORKBENCH_DATABASE_PATH=backend/data/app.db
WORKBENCH_DEFAULT_USERNAME=admin
WORKBENCH_DEFAULT_PASSWORD=admin123
WORKBENCH_SESSION_COOKIE_SECURE=0
WORKBENCH_SESSION_COOKIE_SAMESITE=lax

# Redis visual queue
REDIS_URL=redis://127.0.0.1:6379/0
VISUAL_QUEUE_REDIS_ENABLED=1
VISUAL_QUEUE_NAME=visual:tasks:queue
VISUAL_QUEUE_RETRY_NAME=visual:tasks:retry
VISUAL_QUEUE_DEAD_NAME=visual:tasks:dead
VISUAL_QUEUE_DRAIN_MAX_JOBS=2
VISUAL_QUEUE_WORKER_LOCK_SECONDS=3600
VISUAL_QUEUE_POP_TIMEOUT_SECONDS=1
VISUAL_QUEUE_MAX_RETRIES=2
VISUAL_QUEUE_RETRY_DELAY_SECONDS=30
VISUAL_USER_CONCURRENCY_LIMIT=1
VISUAL_TEAM_CONCURRENCY_LIMIT=3

# AI API, OpenAI-compatible
OPENAI_API_KEY=replace_me
OPENAI_BASE_URL=https://svip.fluapi.com/v1
OPENAI_TEXT_MODEL=gpt-5.5
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=medium

# Aliyun OSS
ALIYUN_OSS_ENABLED=1
ALIYUN_OSS_ACCESS_KEY_ID=replace_me
ALIYUN_OSS_ACCESS_KEY_SECRET=replace_me
ALIYUN_OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
ALIYUN_OSS_BUCKET=replace_me
ALIYUN_OSS_PUBLIC_BASE_URL=https://replace_me.oss-cn-beijing.aliyuncs.com
ALIYUN_OSS_OBJECT_PREFIX=temu-listing

# 1688 image search API
TMAPI_API_TOKEN=
TMAPI_BASE_URL=http://api.tmapi.top
